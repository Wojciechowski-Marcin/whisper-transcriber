# ─── Transcription backend (any OpenAI-compatible /audio/transcriptions endpoint) ───
# Your self-hosted Whisper, OpenAI, Groq, etc.
WHISPER_API_URL=http://192.168.40.180:9000/v1/audio/transcriptions

# API key sent as "Authorization: Bearer <key>". Use "not-needed" for endpoints
# that don't authenticate (e.g. a private self-hosted Whisper).
WHISPER_API_KEY=not-needed

# Model name passed to the endpoint. Ignored by some self-hosted servers;
# required by OpenAI ("whisper-1") / Groq ("whisper-large-v3").
WHISPER_MODEL=whisper-1

# ─── App behaviour ───
# Max upload size in megabytes (rejected before conversion).
MAX_UPLOAD_MB=200

# Upstream transcription request timeout, seconds (long audio can be slow).
REQUEST_TIMEOUT=600

# Where transcripts are persisted (one folder per job). Mounted as a volume.
OUTPUT_DIR=/data/outputs

# CORS allowed origins, comma-separated. "*" allows any origin.
ALLOWED_ORIGINS=*
